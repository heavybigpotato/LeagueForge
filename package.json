{
  "name": "leagueforge",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "LeagueForge \u2014 premium league management platform",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc -b",
    "format": "prettier --write src"
  },
  "dependencies": {
    "@fontsource-variable/outfit": "^5.2.8",
    "@types/qrcode": "^1.5.6",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.9.4",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.4.0",
    "vitest": "^2.0.5"
  }
}